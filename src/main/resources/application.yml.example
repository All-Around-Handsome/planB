server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/imagineers?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: 본인_DB_사용자명
    password: 본인_DB_비밀번호
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

# Swagger 경로 설정
springdoc:
  swagger-ui:
    path: /swagger-ui.html
  api-docs:
    path: /v3/api-docs

jwt:
  # 최소 64자 이상의 긴 문자열을 직접 생성해서 넣으세요
  secret: 본인_JWT_시크릿_64자이상
  access-token-expiration: 3600000
  refresh-token-expiration: 1209600000

oauth:
  kakao:
    # 카카오 개발자 콘솔의 REST API 키
    client-id: 카카오_REST_API_키
    redirect-uri: http://localhost:5173/oauth/kakao
    token-uri: https://kauth.kakao.com/oauth/token
    user-info-uri: https://kapi.kakao.com/v2/user/me
  google:
    client-id: 구글_CLIENT_ID
    client-secret: 구글_CLIENT_SECRET
    redirect-uri: http://localhost:5173/oauth/google
    token-uri: https://oauth2.googleapis.com/token
    user-info-uri: https://www.googleapis.com/oauth2/v3/userinfo